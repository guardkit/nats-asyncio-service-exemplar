# Example Service Configuration
# Copy to .env and adjust values as needed.
# All variables are prefixed with SERVICE_.

SERVICE_NATS_URL=nats://localhost:4222
SERVICE_NATS_CONNECT_TIMEOUT=5.0
SERVICE_NATS_RECONNECT_TIME_WAIT=2.0
SERVICE_NATS_MAX_RECONNECT_ATTEMPTS=60
SERVICE_LOG_LEVEL=INFO
SERVICE_SERVICE_NAME=example-service
